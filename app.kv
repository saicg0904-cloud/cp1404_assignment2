#:kivy 2.2.0

<TravelTrackerApp>:
    BoxLayout:
        orientation: 'vertical'
        padding: 10
        spacing: 10

        Label:
            text: root.status_label.text
            size_hint: (1, 0.1)
            font_size: 18

        BoxLayout:
            id: places_layout
            orientation: 'vertical'
            size_hint: (1, 0.7)

        BoxLayout:
            orientation: 'horizontal'
            size_hint: (1, 0.2)
            spacing: 5

            TextInput:
                id: name_input
                hint_text: "Name"
                size_hint: (0.3, 1)

            TextInput:
                id: country_input
                hint_text: "Country"
                size_hint: (0.3, 1)

            Spinner:
                id: priority_spinner
                text: "1"
                values: [str(i) for i in range(1, 6)]
                size_hint: (0.2, 1)

            Button:
                text: "Add Place"
                size_hint: (0.2, 1)
                on_press: root.add_place(self)