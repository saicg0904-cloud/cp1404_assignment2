#:kivy 2.0.0

BoxLayout:
    orientation: 'vertical'
    padding: 10
    spacing: 5

    Label:
        id: status_label
        text: "Places to visit: 0"
        size_hint_y: 0.1

    GridLayout:
        id: place_layout
        cols: 1
        size_hint_y: 0.5

    BoxLayout:
        size_hint_y: 0.1
        spacing: 5
        TextInput:
            id: name_input
            hint_text: "Name"
        TextInput:
            id: country_input
            hint_text: "Country"
        TextInput:
            id: priority_input
            hint_text: "Priority"
        Button:
            text: "Add"
            on_press: app.add_new_place()
        Button:
            text: "Clear"
            on_press: app.clear_inputs()

    Spinner:
        id: sort_spinner
        text: "name"
        values: ["name", "country", "priority", "visited"]
        on_text: app.sort_places()
        size_hint_y: 0.1

    Label:
        id: message_label
        text: ""
        size_hint_y: 0.1